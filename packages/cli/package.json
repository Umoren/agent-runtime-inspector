{
  "name": "@ari/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "ari": "./dist/index.js"
  },
  "scripts": {
    "ari": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ari/collector": "workspace:*",
    "@ari/core": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
