{
  "name": "agent-runtime-inspector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "ari": "tsx packages/cli/src/index.ts",
    "dev": "tsx packages/cli/src/index.ts dev",
    "web:dev": "pnpm --filter @ari/web dev",
    "example:merge": "pnpm --filter @ari/example-vercel-ai-sdk-merge dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.29.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.0"
  }
}
